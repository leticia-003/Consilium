@startuml
skinparam componentStyle uml2

title AIMA 2.0 High-Level System Architecture

' Define Packages (Layers)
package "Presentation Layer (Angular Frontend)" as Frontend {
  [Client Portal] as ClientUI
  [Lawyer Portal] as LawyerUI
  [Homepage] as HomeUI
}

package "Application Layer (C# Backend / API)" as Backend {
    component "API Gateway" as API_GW
    component "Auth Service" as AUTH
    component "Client/Lawyer Service" as USER_SVC
    component "Process Management Service" as PROCESS_SVC
    component "Document Service" as DOC_SVC
    component "Communication Service" as COMM_SVC
}

package "Data & External Layer" as DataExternal {
    database "Relational DB (PostgreSQL)" as PG_DB
    database "Non-Relational DB (Qdrant/Vector)" as QDRANT_DB
    cloud "AI/Chatbot Service" as CHATBOT
    storage "File Storage (S3/Azure)" as FILE_STORE
    cloud "Email/SMS Service" as EMAIL_SVC
}

' ==========================================================
' Define Connections and Flow
' ==========================================================

' 1. Frontend to Backend
ClientUI --> API_GW : Requests/Auth/Data
LawyerUI --> API_GW : Requests/Auth/Data
HomeUI --> API_GW

' 2. API Gateway to Backend Services
API_GW --> AUTH : Login/Register
API_GW --> USER_SVC : CRUD Clients/Lawyers
API_GW --> PROCESS_SVC : CRUD Processes/Tracking
API_GW --> DOC_SVC : Document CRUD/Download
API_GW --> COMM_SVC : Notifications/Updates
API_GW --> CHATBOT : Chat/Queries

' 3. Backend Services to Data Layer
AUTH --> PG_DB : Read/Write User Data
USER_SVC --> PG_DB : Read/Write Client/Lawyer Data
PROCESS_SVC --> PG_DB : Read/Write Process Data

DOC_SVC --> FILE_STORE : Upload/Download Files

' 4. External Service Connections
COMM_SVC --> EMAIL_SVC : Send Email/SMS

CHATBOT --> QDRANT_DB : Query Legal Knowledgebase
QDRANT_DB <--> PROCESS_SVC : Jurisprudence Search
